VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-key

# Origin used in auth email links (magic link / password reset).
# Defaults to window.location.origin, which is wrong inside the Capacitor
# app shell (it resolves to capacitor://localhost). Set this explicitly
# when building the native app so those emails point at the real site.
VITE_PUBLIC_URL=https://tikcal.nyc
